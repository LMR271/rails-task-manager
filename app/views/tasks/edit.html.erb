  <h1>Edit task</h1>

  <%= form_with model: @task, url: url_for(controller: 'tasks', action: 'update', id: @task.id), method: :patch do |f| %>
    <p>
      <strong>Title</strong><br>
      <%= f.text_field :title %>
    </p>

    <p>
      <strong>Details</strong><br>
      <%= f.text_area :details %>
    </p>

    <%= f.check_box :completed %> Completed<br>

    <%= f.submit "Update Task" %>
  <% end %>

  <%= link_to "Back to list", tasklist_path %>
