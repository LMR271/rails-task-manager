  <h1>New task</h1>

  <%= form_with model: @task, url: createnew_path do |f| %>
    <p>
      <strong>Title</strong><br>
      <%= f.text_field :title %>
    </p>

    <p>
      <strong>Details</strong><br>
      <%= f.text_area :details %>
    </p>

    <%= f.submit "Create Task" %>
  <% end %>

  <%= link_to "Back to list", tasklist_path %>
